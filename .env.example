# App
# `NODE_ENV`는 보통 `.env`에 고정하지 않는 편이 안전합니다.
# - `npm run dev`: Next가 development로 실행됩니다.
# - Docker 이미지: Dockerfile에서 production으로 실행됩니다.
# - 예외적으로 `npm run dev`에서 production을 강제하면 안 됩니다.
#   (production + http://localhost 조합이면 Secure 쿠키가 저장되지 않아 로그인처럼 보입니다.)
PORT=3000
BASE_URL=http://localhost:3000

# 운영(HTTPS)에서 쿠키 Secure를 강제하려면 true로 설정하세요.
# 로컬에서 BASE_URL이 https인데 http로 접속하는 경우에는 false로 두세요.
# COOKIE_SECURE=true

# Database
# Docker Compose로 앱+DB를 같이 띄울 때(컨테이너 내부): 호스트 이름은 보통 `postgres`
DATABASE_URL=postgresql://study_user:change_me@postgres:5432/study_archive?schema=public
#
# 맥에서 `npm run dev`로 호스트에서 실행할 때: DB를 호스트로 노출했다면 `127.0.0.1`
# DATABASE_URL=postgresql://study_user:change_me@127.0.0.1:5432/study_archive?schema=public

# Auth
AUTH_SECRET=replace-with-a-random-32+-char-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-very-strong-password

# Upload
MAX_UPLOAD_SIZE_MB=10
